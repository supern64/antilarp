# --- Discord ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: set for instant command registration during dev (guild-scoped).
# Leave blank to register commands globally (can take up to ~1hr to propagate).
DISCORD_GUILD_ID=

# --- Microsoft Entra ID ---
# Your restricted tenant ID (NOT "organizations" / "common").
MS_TENANT_ID=9bc585f9-a8b8-431c-9013-efa7b2b40cdf
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Must exactly match a "Web" platform redirect URI registered on the app,
# and must be HTTPS in production (Entra ID only allows plain http for localhost).
MS_REDIRECT_URI=https://your-domain.example.com/callback

# --- Server ---
PORT=3000

# --- Student ID parsing ---
# Expected format: U + XX (enrollment year, BE) + YY (faculty code) + ZZZ (ordinal)
STUDENT_EMAIL_DOMAIN=student.mahidol.ac.th

# --- OAuth state ---
STATE_TTL_MINUTES=10
